    "sha256": "{{SHA256_HASH}}",
    "components_count": 0,
    "nets_count": 0,
    "power_domains": []
  },
  
  "component_manifest": {
    "path": "candidates/{{CANDIDATE_ID}}/component_manifest.json",
    "sha256": "{{SHA256_HASH}}",
    "total_components": 0,
    "datasheets_linked": 0,
    "availability_checked": false
  },
  
  "kicad_artifacts": {
