  "title": "{{TITLE}}",
  "risk_level": "{{RISK_LEVEL}}",
  "created": "{{ISO8601_TIMESTAMP}}",
  "updated": "{{ISO8601_TIMESTAMP}}",
  
  "task_brief": {
    "path": "task_brief.md",
    "sha256": "{{SHA256_HASH}}",
    "reviewed": true,
    "reviewer": "{{REVIEWER_NAME}}",
    "review_date": "{{ISO8601_DATE}}"
  },
  
  "circuit_ir": {
    "path": "candidates/{{CANDIDATE_ID}}/circuit_ir.json",
