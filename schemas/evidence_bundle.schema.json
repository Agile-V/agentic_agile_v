{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agentic Agile-V Evidence Bundle",
  "type": "object",
  "required": [
    "task_id",
    "title",
    "task_type",
    "risk_level",
    "requirement_ids",
    "brief_path",
    "plan_path",
    "changed_files",
    "tests",
    "checks",
    "evidence_artifacts",
    "reviewer_gate",
    "rollback_path",
    "residual_risks"
  ],
  "properties": {
    "task_id": {"type": "string", "pattern": "^[A-Z]+-[0-9]+$"},
    "title": {"type": "string", "minLength": 1},
    "task_type": {"type": "string", "enum": ["feature", "bug", "hardware", "firmware", "test", "refactor", "docs", "security", "other"]},
    "risk_level": {"type": "string", "enum": ["L0", "L1", "L2", "L3", "L4"]},
    "requirement_ids": {"type": "array", "items": {"type": "string"}},
    "brief_path": {"type": "string"},
    "plan_path": {"type": "string"},
    "changed_files": {"type": "array", "items": {"type": "string"}},
    "tests": {"type": "array", "items": {"type": "object"}},
    "checks": {"type": "array", "items": {"type": "object"}},
    "evidence_artifacts": {"type": "array", "items": {"type": "string"}},
    "reviewer_gate": {"type": "object"},
    "rollback_path": {"type": "string"},
    "residual_risks": {"type": "array", "items": {"type": "string"}},
    "agent_execution": {
      "type": "object",
      "description": "Agent execution metadata (optional, only present if agent was used)",
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["openhands", "cursor", "continue", "windsurf", "cline", "manual"],
          "description": "Execution engine used"
        },
        "mode": {
          "type": "string",
          "enum": ["builder", "verifier", "risk_classifier"],
          "description": "Agent mode"
        },
        "session_id": {
          "type": "string",
          "description": "Unique session identifier"
        },
        "agent_model": {
          "type": "string",
          "description": "LLM model used (e.g., claude-3.5-sonnet, gpt-4)"
        },
        "started_at": {
          "type": "string",
          "format": "date-time",
          "description": "Session start timestamp (ISO 8601)"
        },
        "ended_at": {
          "type": "string",
          "format": "date-time",
          "description": "Session end timestamp (ISO 8601)"
        },
        "tool_log_path": {
          "type": "string",
          "description": "Relative path to tool usage log (JSONL format)"
        },
        "handoff_path": {
          "type": "string",
          "description": "Relative path to session handoff document"
        }
      },
      "required": ["engine", "mode", "session_id"]
    },
    "scope_control": {
      "type": "object",
      "description": "Scope validation metadata (optional)",
      "properties": {
        "allowed_paths": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Glob patterns for allowed file changes"
        },
        "blocked_paths": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Glob patterns for blocked file changes"
        },
        "changed_files_within_scope": {
          "type": "boolean",
          "description": "Whether all changed files are within allowed scope"
        },
        "out_of_scope_changes": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Files changed that are outside allowed scope"
        },
        "dependency_changes": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Dependency files that were changed"
        },
        "public_api_changes": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Public API files that were changed"
        }
      }
    },
    "control_matrix": {
      "type": "object",
      "description": "Control matrix evidence (required for L2+). Records the selected control ID, matrix path, policy version, decisions, owners, rollback, cost, and log references.",
      "required": ["control_id", "matrix_path", "policy_version", "decisions", "owner", "rollback", "cost"],
      "properties": {
        "control_id": {
          "type": "string",
          "description": "ID of the resolved control entry (e.g. cm-default-agentic-task)"
        },
        "matrix_path": {
          "type": "string",
          "description": "Relative path to the control matrix file used"
        },
        "policy_version": {
          "type": "string",
          "description": "Version field from the control matrix"
        },
        "decisions": {
          "type": "array",
          "description": "List of control decisions made during the task",
          "items": {
            "type": "object",
            "required": ["timestamp", "check", "decision", "reason"],
            "properties": {
              "timestamp": {"type": "string"},
              "check": {"type": "string"},
              "decision": {"type": "string", "enum": ["allow", "deny", "require_human_gate", "warn"]},
              "reason": {"type": "string"},
              "approval_ref": {"type": "string"}
            }
          }
        },
        "owner": {
          "type": "object",
          "description": "Owner snapshot from the resolved control entry"
        },
        "rollback": {
          "type": "object",
          "description": "Rollback evidence and strategy reference"
        },
        "cost": {
          "type": "object",
          "description": "Cost record for the task run",
          "properties": {
            "run_cost": {"type": "number"},
            "daily_cost": {"type": "number"},
            "currency": {"type": "string"}
          }
        },
        "log_refs": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Paths to control event log files"
        }
      }
    },
    "verification": {
      "type": "object",
      "description": "Independent verification metadata (required for L2+)",
      "properties": {
        "builder_summary_path": {
          "type": "string",
          "description": "Path to builder implementation summary"
        },
        "verifier_report_path": {
          "type": "string",
          "description": "Path to independent verifier report"
        },
        "fresh_context_verification": {
          "type": "boolean",
          "description": "Whether verifier started from fresh context (no builder memory)"
        },
        "verifier_result": {
          "type": "string",
          "enum": ["pass", "fail", "needs-human-review"],
          "description": "Verifier recommendation"
        },
        "criteria_coverage": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "criterion": {"type": "string"},
              "evidence": {"type": "string"},
              "satisfied": {"type": "boolean"}
            }
          },
          "description": "Mapping of acceptance criteria to evidence"
        }
      }
    },
    "knowledge_snapshot": {
      "type": "object",
      "description": "Snapshot of the OpenWiki knowledge layer (openwiki/) at evidence-collection time. Written by 'agilev wiki snapshot'.",
      "required": ["wiki_dir", "page_count", "validation_passed"],
      "properties": {
        "wiki_dir": {
          "type": "string",
          "description": "Repo-relative directory containing generated wiki pages (default: openwiki)"
        },
        "manifest_path": {
          "type": "string",
          "description": "Path to the Agile-V wiki manifest (.agile-v/wiki/manifest.json)"
        },
        "manifest_generated_at": {
          "type": ["string", "null"],
          "description": "Timestamp (ISO 8601) the manifest was last generated"
        },
        "page_count": {
          "type": "integer",
          "description": "Number of wiki pages tracked in the manifest"
        },
        "pages": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Relative paths of tracked wiki pages"
        },
        "required_pages": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Pages required for this repository's detected domains"
        },
        "validation_passed": {
          "type": "boolean",
          "description": "Whether 'agilev wiki validate' passed at capture time"
        },
        "validation_errors": {
          "type": "array",
          "items": {"type": "string"}
        },
        "validation_warnings": {
          "type": "array",
          "items": {"type": "string"}
        },
        "stale_pages": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Pages whose declared sources changed after the manifest was generated"
        },
        "captured_at": {
          "type": "string",
          "description": "Timestamp (ISO 8601) the snapshot was captured"
        }
      }
    }
  }
}
